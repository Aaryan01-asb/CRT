#include <iostream>
using namespace std;

class player {
public:
    string name;
    void setName(string n) {
        name = n;
    }
};

class cricketer : public player {
public:
    int runs;
    void setRun(int r) {
        runs = r;
    }
    void show() {
        cout << "name: " << name << endl;
        cout << "runs: " << runs << endl;
    }
};

int main() {
    string n;
    int r;

    cout << "Enter player name: ";
    cin >> n;

    cout << "Enter runs: ";
    cin >> r;

    cricketer c1;
    c1.setName(n);
    c1.setRun(r);

    c1.show();
    return 0;
}
